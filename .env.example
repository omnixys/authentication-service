NODE_ENV=development
SERVICE=authentication-service
PORT=4000
SCHEMA_TARGET=true
HTTPS=false
KEYS_PATH=./keys

DATABASE_URL=postgresql://authentication:change-me@localhost:5432/authentication
SHADOW_DATABASE_URL=
DATABASE_URL_LOCALE=

KC_URL=http://localhost:18080/auth
KC_REALM=omnixys
KC_CLIENT_ID=authentication-service
KC_CLIENT_SECRET=change-me
KC_ADMIN_USERNAME=admin
KC_ADMIN_PASSWORD=change-me
KC_TLS_REJECT_UNAUTHORIZED=true

KAFKA_BROKER=localhost:9092
VALKEY_URL=valkey://localhost:6380
VALKEY_PASSWORD=change-me

TEMPO_URI=http://localhost:4318/v1/traces
KEYCLOAK_HEALTH_URL=
TEMPO_HEALTH_URL=
PROMETHEUS_HEALTH_URL=

COOKIE_SECRET=replace-with-at-least-32-random-bytes
PC_JWE_KEY=replace-with-exactly-32-raw-bytes-or-base64-encoded-32-bytes
PC_TTL_SEC=2592000
RESET_TOKEN_HMAC_SECRET=replace-with-random-secret
DEVICE_FINGERPRINT_HMAC_SECRET=replace-with-random-secret
MAGIC_LINK_HMAC_SECRET=replace-with-random-secret
ENCRYPTION_KEY=replace-with-random-secret
FINGERPRINT_SECRET=replace-with-random-secret

LOG_LEVEL=info
LOG_PRETTY=false
LOG_DEFAULT=false
LOG_DIRECTORY=log
LOG_FILE_DEFAULT_NAME=server.log
