generator client {
  provider = "prisma-client"
  output   = "../src/prisma/generated"
}

datasource db {
  provider = "postgresql"
}

enum MfaPreference {
  NONE
  TOTP
  WEBAUTHN
  BACKUP_CODES
  SECURITY_QUESTIONS

  @@map("mfa_preference")
}

enum ResetTokenState {
  ISSUED
  TOKEN_VERIFIED
  STEP_UP_VERIFIED
  COMPLETED
  LOCKED
  EXPIRED

  @@map("reset_token_state")
}

enum SecurityQuestionType {
  FIRST_PET
  BIRTH_CITY
  MOTHER_MAIDEN_NAME
  FAVORITE_SCHOOL_SUBJECT
  CHILDHOOD_BEST_FRIEND
  FAVOURITE_COMPANY
  BIRTH_DATE

  @@map("security_question_key")
}

model AuthUser {
  id       String @id @default(uuid()) @db.Uuid
  email    String @unique
  username String @unique

  mfaPreference MfaPreference @default(NONE) @map("mfa_preference")

  failedAttempts Int       @default(0) @map("failed_attempts")
  lockedUntil    DateTime? @map("locked_until")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  totp              TotpCredential?
  webAuthn          WebAuthnCredential[]
  backupCodes       BackupCode[]
  securityQuestions UserSecurityQuestion[]
  resetTokens       PasswordResetToken[]
  knownDevices      KnownDevice[]
  loginHistories    LoginHistory[]
  oauthAccounts     OAuthAccount[]

  @@index([email])
  @@index([username])
  @@map("auth_user")
}

model TotpCredential {
  id              String  @id @default(uuid()) @db.Uuid
  encryptedSecret String  @map("encrypted_secret")
  enabled         Boolean @default(false)

  userId String   @unique @map("user_id") @db.Uuid
  user   AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("totp_credential")
}

model WebAuthnCredential {
  id           String  @id @default(uuid()) @db.Uuid
  credentialId String  @unique @map("credential_id") @db.Uuid
  publicKey    String  @map("public_key")
  counter      Int
  deviceType   String  @map("device_type")
  backedUp     Boolean @map("backed_up")
  transports   String?

  nickname   String? // 👈 user-defined name
  createdAt  DateTime  @default(now()) @map("created_at")
  lastUsedAt DateTime? @map("last_used_at")
  revokedAt  DateTime? @map("revoked_at")

  user   AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String   @map("user_id") @db.Uuid

  @@index([userId])
  @@map("web_auth_n_credentials")
}

model BackupCode {
  id       String    @id @default(uuid()) @db.Uuid
  codeHash String    @map("code_hash")
  usedAt   DateTime? @map("used_at")

  userId String   @map("user_id") @db.Uuid
  user   AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("backup_code")
}

model SecurityQuestion {
  id       String               @id @default(uuid()) @db.Uuid
  key      SecurityQuestionType @unique
  question String               @unique

  userAnswers UserSecurityQuestion[]

  @@map("security_question")
}

model UserSecurityQuestion {
  id         String @id @default(uuid()) @db.Uuid
  answerHash String @map("answer_hash")

  user   AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String   @map("user_id") @db.Uuid

  questionId String           @map("question_id") @db.Uuid
  question   SecurityQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([userId])
  @@map("user_security_question")
}

model PasswordResetToken {
  id String @id @default(uuid()) @db.Uuid

  tokenHash       String          @map("token_hash")
  tokenLookupHash String          @unique @map("token_lookup_hash")
  state           ResetTokenState @default(ISSUED)

  expiresAt DateTime  @map("expires_at")
  attempts  Int       @default(0)
  locked    Boolean   @default(false)
  usedAt    DateTime? @map("used_at")

  userId String   @map("user_id") @db.Uuid
  user   AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
  @@index([tokenLookupHash, expiresAt])
  @@map("password_reset_token")
}

model RateLimitBucket {
  id          String    @id @default(uuid()) @db.Uuid
  key         String    @unique
  windowStart DateTime  @map("window_start")
  count       Int
  lockedUntil DateTime? @map("locked_until")

  @@unique([key, windowStart])
  @@map("rate_limit_bucket")
}

model KnownDevice {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  fingerprint String   @map("finger_print")
  firstSeen   DateTime @default(now()) @map("first_seen")
  lastSeen    DateTime @updatedAt @map("last_seen")

  user AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, fingerprint])
  @@index([userId])
  @@map("known_device")
}

model LoginHistory {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  ip        String
  country   String?
  city      String?
  createdAt DateTime @default(now()) @map("created_at")

  user AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId])
  @@map("login_history")
}

model OAuthAccount {
  id         String   @id @default(uuid()) @db.Uuid
  provider   String
  providerId String   @map("provider_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  user       AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@index([userId])
  @@map("o_auth_account")
}
