{
  "name": "authentication-service",
  "version": "2.1.0",
  "description": "Omnixys Authentication Service – zentrale Authentifizierungs- und Autorisierungskomponente (Keycloak, JWT, SSO).",
  "author": {
    "name": "Caleb Gyamfi",
    "email": "caleb@omnixys.com",
    "url": "https://omnixys.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/omnixys/authentication-service.git"
  },
  "bugs": {
    "url": "https://github.com/omnixys/authentication-service/issues"
  },
  "homepage": "https://omnixys.com",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "private": false,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=25.8.2",
    "pnpm": ">=10.33.0"
  },
  "scripts": {
    "clean": "rm -rf dist tsconfig.build.tsbuildinfo",
    "build": "pnpm run clean && nest build",
    "format": "prettier --cache --write \"src/**/*.{ts,js,json,prisma,md,yaml}\"",
    "format:test": "prettier --cache --write \"src/**/*.{ts,js,json,prisma,md,yaml}\" \"__tests__/**/*.ts\"",
    "format:check": "prettier --cache --check \"src/**/*.{ts,js,json,prisma,md,yaml,yml}\" \"__test__/**/*.ts\"",
    "start": "pnpm nest start",
    "dev": "pnpm run clean && nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "typedoc": "typedoc",
    "depcheck": "depcheck",
    "prepare": "husky",
    "generate": "pnpm prisma format && pnpm prisma validate && prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio --schema prisma/schema.prisma",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:push": "prisma db push",
    "prisma:pull": "prisma db pull",
    "prisma:reset:locale": "prisma migrate reset --force && prisma migrate dev && tsx prisma/seed.ts",
    "reset": "prisma migrate reset --force && prisma migrate dev && tsx prisma/seed.ts",
    "prisma:format": "pnpm prisma format && pnpm prisma validate && prisma generate",
    "release": "semantic-release",
    "test": "pnpm run test:unit && pnpm run test:integration",
    "test:unit": "pnpm run build && node --test __tests__/unit/*.test.mjs",
    "test:integration": "pnpm run build && node --test __tests__/integration/*.test.mjs",
    "test:e2e": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test22": "vitest run __tests__/e2e/authentication/test2.e2e-spec.ts",
    "test223": "vitest run __tests__/e2e/authentication/test2.e2e-spec.ts --reporter=verbose --silent=false"
  },
  "dependencies": {
    "@apollo/server": "^5.5.1",
    "@apollo/subgraph": "^2.14.2",
    "@as-integrations/fastify": "^3.1.0",
    "@fastify/compress": "^8.3.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@nestjs/apollo": "^13.4.2",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/graphql": "^13.4.2",
    "@nestjs/platform-fastify": "^11.1.27",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/terminus": "^11.1.1",
    "@omnixys/cache": "^2.0.2",
    "@omnixys/context": "^2.0.0",
    "@omnixys/contracts": "^2.0.0",
    "@omnixys/graphql": "^2.0.1",
    "@omnixys/kafka": "^2.1.1",
    "@omnixys/logger": "^2.0.1",
    "@omnixys/observability": "^2.0.0",
    "@omnixys/security": "^2.1.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@simplewebauthn/server": "^13.3.2",
    "@testcontainers/kafka": "^11.14.0",
    "@valkey/client": "^1.0.0",
    "argon2": "^0.44.0",
    "cfonts": "^3.3.1",
    "chalk": "^5.6.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "cron": "^4.4.0",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "fastify": "5.8.5",
    "geoip-lite": "^2.0.3",
    "graphql": "^16.14.2",
    "jose": "^6.2.3",
    "kafkajs": "^2.2.4",
    "otplib": "^13.4.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/js": "^9.39.4",
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "latest",
    "@nestjs/testing": "^11.1.27",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.15.43",
    "@testcontainers/postgresql": "^11.14.0",
    "@tsconfig/node23": "^23.0.4",
    "@types/geoip-lite": "^1.4.4",
    "@types/node": "^22.20.0",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "depcheck": "^1.4.7",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.9.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-sort-imports": "^1.8.11",
    "prisma": "^7.8.0",
    "semantic-release": "^25.0.5",
    "supertest": "^7.2.2",
    "testcontainers": "^11.14.0",
    "ts-morph": "^27.0.2",
    "tsx": "^4.22.4",
    "typedoc": "^0.28.19",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "overrides": {
      "fastify": "5.8.5"
    }
  }
}
